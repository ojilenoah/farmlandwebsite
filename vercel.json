{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/products",
      "destination": "/products.html"
    },
    {
      "source": "/products.html",
      "destination": "/products.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
